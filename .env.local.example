# ══════════════════════════════════════════════════════
# SureEdge — Environment Variables
# Copy this file to .env.local and fill in the values
# ══════════════════════════════════════════════════════

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Supabase service role — OBRIGATÓRIO para as rotas API de servidor (SSE, freebet, queue, events).
# Encontre em: Supabase Dashboard → Settings → API → service_role (secret).
# NÃO exponha este valor no frontend. Usado apenas em API routes (server-side).
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_SECRET_KEY
